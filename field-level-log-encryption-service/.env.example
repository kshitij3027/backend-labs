# Field-Level Log Encryption Service — example environment file.
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# --- Web / server ---
# HTTP port the FastAPI app listens on inside the container.
PORT=8000
# Application log level. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# --- Key management ---
# Base64-encoded 32-byte KEK used to wrap Data Encryption Keys.
# Generate via: python -c 'import os,base64; print(base64.b64encode(os.urandom(32)).decode())'
MASTER_KEY_B64=
# Days between automatic DEK rotations.
KEY_ROTATION_DAYS=30

# --- Performance / batching ---
# Minimum number of sensitive fields in a log before parallel encryption kicks in.
BATCH_PARALLEL_THRESHOLD_FIELDS=4
# Minimum total plaintext byte count across sensitive fields before parallel encryption kicks in.
BATCH_PARALLEL_THRESHOLD_BYTES=4096
# Worker thread count for the parallel encryption pool.
THREAD_POOL_SIZE=4

# --- Cache (Redis is wired in commit C9) ---
# Redis host the app will talk to. `redis` is the service name in docker-compose.
REDIS_HOST=redis
# Redis port.
REDIS_PORT=6379
