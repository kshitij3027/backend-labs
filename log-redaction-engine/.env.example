# Intelligent Log Redaction Engine — example environment file.
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# --- Web / server ---
# HTTP port the FastAPI app listens on inside the container.
PORT=8000
# Application log level. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# --- Redaction core ---
# Active redaction preset name. Resolved against ``config/presets/<name>.json``
# at startup. Ships with three presets: ``general`` (GDPR), ``healthcare``
# (HIPAA), and ``financial`` (PCI_DSS + GDPR).
REDACTION_PRESET=general
# REQUIRED. Hex salt used by the ``hash`` redaction strategy so output is
# deterministic within a deployment but unguessable across deployments.
# The service fails fast at startup if this is unset.
# generate via: python -c 'import secrets; print(secrets.token_hex(32))'
REDACTION_HASH_SALT=

# --- Named entity recognition (spaCy en_core_web_sm) ---
# Minimum input length (chars) before NER runs; short fragments rarely
# contain person/org names worth detecting and NER is the slowest stage,
# so this is the cheapest place to filter.
NER_MIN_LENGTH=40
# Master switch for the NER stage. Set to ``false`` for regex-only mode
# (skips the spaCy load entirely and never invokes it on a request).
NER_ENABLED=true

# --- Observability / metrics ---
# Maximum number of audit events held in the in-memory ring buffer
# before the oldest are dropped. Compliance reports aggregate across
# whatever's currently retained.
AUDIT_BUFFER_SIZE=10000
# Sliding window (seconds) for the throughput / latency stats counters.
STATS_WINDOW_SECONDS=60

# --- Performance / batching ---
# Maximum number of distinct values the token store retains before
# rejecting new tokenizations (protects against unbounded growth).
MAX_TOKEN_COUNT=100000
# Minimum batch size before parallel processing kicks in. Smaller batches
# stay on the serial path so the thread-pool dispatch overhead doesn't
# dominate the per-entry work.
BATCH_PARALLEL_THRESHOLD=50
# Worker thread count for the CPU-bound redaction pool.
THREAD_POOL_SIZE=4
# Per-pattern regex evaluation budget (seconds). Bounds catastrophic
# backtracking on adversarial input — patterns exceeding the budget
# return no match and the engine continues on the remaining patterns.
REGEX_TIMEOUT_SEC=0.05

# --- Cache (Redis backend for cross-process token-mirror consistency) ---
# Redis host the app will talk to. ``redis`` is the docker-compose
# service name; override for external Redis.
REDIS_HOST=redis
# Redis port.
REDIS_PORT=6379
# Master switch for Redis-backed caching. When false (or when the Redis
# ping fails at startup) the service falls back to an in-memory backend.
REDIS_ENABLED=false
