# Intelligent Log Redaction Engine - example environment file.
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# --- Web / server ---
# HTTP port the FastAPI app listens on inside the container.
PORT=8000
# Application log level. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# --- Redaction core ---
# Active redaction preset name. ``general`` is the catch-all preset; ``hipaa``,
# ``pci``, ``gdpr`` are layered on in later commits.
REDACTION_PRESET=general
# REQUIRED. Hex salt used by hash-based redaction so output is deterministic
# within a deployment but unguessable across deployments.
# generate via: python -c 'import secrets; print(secrets.token_hex(32))'
REDACTION_HASH_SALT=

# --- Named entity recognition (spaCy en_core_web_sm) ---
# Minimum input length (chars) before NER runs; short fragments rarely
# contain person/org names worth detecting.
NER_MIN_LENGTH=40
# Master switch for the NER stage. Set to ``false`` for regex-only mode.
NER_ENABLED=true

# --- Observability / metrics ---
# Maximum number of audit events held in memory before the oldest are dropped.
AUDIT_BUFFER_SIZE=10000
# Sliding window (seconds) for throughput / latency stats.
STATS_WINDOW_SECONDS=60

# --- Performance / batching ---
# Maximum number of input tokens accepted in a single batch request.
MAX_TOKEN_COUNT=100000
# Minimum batch size before parallel processing kicks in.
BATCH_PARALLEL_THRESHOLD=50
# Worker thread count for the CPU-bound redaction pool.
THREAD_POOL_SIZE=4
# Per-pattern regex evaluation budget (seconds). Bounds catastrophic
# backtracking on adversarial input.
REGEX_TIMEOUT_SEC=0.05

# --- Cache (Redis is wired in commit C10) ---
# Redis host the app will talk to. ``redis`` is the service name docker-
# compose will use once C10 lands.
REDIS_HOST=redis
# Redis port.
REDIS_PORT=6379
# Master switch for Redis-backed caching; default is in-memory.
REDIS_ENABLED=false
