# Example environment for log-fulltext-search-rerank.
# Copy to `.env` (kept out of git) and adjust as needed. Every key here
# maps onto a field on `Settings` in src/config.py and is loaded by
# pydantic-settings at startup.

# --- Server -------------------------------------------------------------------
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
LOG_LEVEL=INFO

# --- Tokenizer ---------------------------------------------------------------
MIN_TOKEN_LENGTH=3
STOP_WORDS_LANGUAGE=english

# --- Temporal decay (half-life in seconds) -----------------------------------
TEMPORAL_HALF_LIFE_NORMAL_S=21600
TEMPORAL_HALF_LIFE_INCIDENT_S=900

# --- Query / search ----------------------------------------------------------
DEFAULT_LIMIT=10
QUERY_CACHE_SIZE=1000
CANDIDATE_TOP_K=200

# --- Index maintenance -------------------------------------------------------
IDF_REBUILD_EVERY_N_DOCS=500
IDF_REBUILD_EVERY_S=2.0

# --- Optional: external config files for synonyms / intent patterns ---------
# SYNONYMS_PATH=/app/src/query/synonyms.default.json
# INTENT_PATTERNS_PATH=

# Note: dict-valued settings (severity_weights, ranking_weights,
# incident_ranking_weights, service_authority_weights) are loaded from
# Settings defaults and aren't overrideable via .env at the moment.
# To customize them, edit src/config.py or pass a Settings instance to
# build_app() in tests/integration code.
