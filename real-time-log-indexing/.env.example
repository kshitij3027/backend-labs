# Example environment file for real-time-log-indexing.
# Copy to .env and uncomment / adjust values as needed.
# Defaults below mirror src/config.py and project_requirements.md Section 7.

# --- Indexing pipeline knobs ---
# BATCH_TIMEOUT_MS=100
# SEGMENT_MAX_DOCS=10000
# SEGMENT_MAX_MEMORY_MB=50
# MAX_MEMORY_SEGMENTS=5

# --- Redis transport ---
# REDIS_URL=redis://localhost:6379
# REDIS_STREAM_NAME=logs
# REDIS_CONSUMER_GROUP=indexer

# --- HTTP server ---
# HTTP_PORT=8080

# --- Segment persistence ---
# DISK_SEGMENT_DIR=./data/segments
# BACKGROUND_MERGE_INTERVAL_S=30

# --- Reconnect / backoff ---
# REDIS_RECONNECT_BACKOFF_BASE_S=0.5
# REDIS_RECONNECT_BACKOFF_MAX_S=30.0

# --- Sample generation ---
# SAMPLE_GENERATION_BATCH_SIZE=500

# --- Observability ---
# LOG_LEVEL=INFO

# --- WebSocket ---
# WS_HEARTBEAT_INTERVAL_S=20
