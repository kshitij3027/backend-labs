# Bloom Filter Log Membership — example environment configuration.
# Copy to `.env` and override as needed. All values shown are the defaults.
# Pydantic reads these case-insensitively (UPPER_SNAKE maps to Settings fields).

# --- API / server ---
API_HOST=0.0.0.0   # interface uvicorn binds to (0.0.0.0 so Docker can publish it)
API_PORT=8001      # TCP port of the membership API (also the host port in compose)

# --- storage ---
DATA_DIR=./data    # directory for persisted filter snapshots (*.bloom); /app/data in compose

# --- per-log-type filter sizing (spec defaults) ---
ERROR_LOGS_CAPACITY=1000000     # expected distinct error-log keys (slice-0 capacity)
ERROR_LOGS_FP_RATE=0.01         # target false-positive rate for error_logs
ACCESS_LOGS_CAPACITY=5000000    # expected distinct access-log keys (slice-0 capacity)
ACCESS_LOGS_FP_RATE=0.05        # target false-positive rate for access_logs
SECURITY_LOGS_CAPACITY=100000   # expected distinct security-log keys (slice-0 capacity)
SECURITY_LOGS_FP_RATE=0.001     # target false-positive rate for security_logs

# --- session tracking filter (Extended A) ---
SESSIONS_CAPACITY=1000000       # expected distinct session IDs per generation (1M DAILY inserts; daily rotation bounds the fill)
SESSIONS_FP_RATE=0.01           # target false-positive rate for sessions (slice 0 ≈ 1.69MB at 1M capacity — under the 2MB criterion)

# --- scalable filter growth (Extended B: adaptive sizing) ---
SBF_GROWTH_FACTOR=2             # capacity multiplier per appended slice (>= 2)
SBF_TIGHTENING_RATIO=0.85       # FP-budget ratio per appended slice (0 < r < 1)

# --- snapshots ---
SNAPSHOT_INTERVAL_SECONDS=30    # background save_all() cadence (seconds)

# --- rotation (Extended B: time-based rotation) ---
ROTATION_MAX_AGE_SECONDS=86400  # rotate a filter generation at this age; 0 disables rotation
ROTATION_CHECK_INTERVAL_SECONDS=60  # how often the rotation task checks generation ages

# --- two-tier pipeline (Extended C) ---
SQLITE_PATH=./data/logs.db   # sqlite "expensive storage" tier backing /pipeline (ground truth); /app/data/logs.db in compose
FP_FALLBACK_THRESHOLD=0.05   # bypass bloom when a filter's live FP estimate exceeds this (meaningful range: 0 < x < 1)
FP_ROTATE_ON_BREACH=true     # rotate a breached filter once per breach episode to restore filter health

# --- logging ---
LOG_LEVEL=INFO     # stdlib logging level (DEBUG / INFO / WARNING / ERROR)
