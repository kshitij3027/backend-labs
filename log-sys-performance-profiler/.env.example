# --- Server ---
PROFILER_PORT=8000

# --- Dashboard ---
DASHBOARD_REFRESH_SEC=2

# --- Bottleneck detection ---
DETECTION_WINDOW_SEC=10
BOTTLENECK_Z_THRESHOLD=2.0

# --- Profiling budget ---
OVERHEAD_TARGET_PCT=2

# --- Metrics buffer ---
METRICS_BUFFER_SIZE=10000
METRICS_BATCH_SIZE=100

# --- Load testing ---
LOAD_TEST_LOG_COUNT=1000
LOAD_TEST_CONCURRENCY=4

# --- Pipeline instrumentation ---
INSTRUMENTED_STAGES=parse,validate,transform,write

# --- Observability ---
LOG_LEVEL=INFO
