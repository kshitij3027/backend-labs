# --- Persistence ---
DATABASE_URL=postgresql+asyncpg://compliance:compliance@postgres:5432/compliance
STORAGE_PATH=./exports

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000

# --- Cryptography ---
# HMAC_SIGNING_KEY must be at least 32 characters. Override in production.
HMAC_SIGNING_KEY=change-me-in-production-this-is-a-32byte-min-key
# Secondary key used for FinHealth dual-signature (commit 17).
HMAC_SIGNING_KEY_SECONDARY=change-me-in-production-secondary-32byte-key!!
# Leave blank to auto-generate a Fernet key at startup (logged as a
# warning; the operator must persist it for restarts).
FERNET_ENCRYPTION_KEY=

# --- Framework configuration ---
SUPPORTED_FRAMEWORKS=SOX,HIPAA,PCI_DSS,GDPR

# --- Report execution ---
MAX_CONCURRENT_REPORTS=5
REPORT_TIMEOUT_SECONDS=300
DEFAULT_EXPORT_FORMAT=PDF

# --- Scheduler ---
SCHEDULER_ENABLED=false
SCHEDULE_INTERVAL=daily

# --- Email distribution (unused until a later commit) ---
EMAIL_SMTP_HOST=
EMAIL_RECIPIENTS=

# --- Observability ---
LOG_LEVEL=INFO

# --- Retention policy (days per framework) ---
DATA_RETENTION_DAYS_SOX=2555
DATA_RETENTION_DAYS_HIPAA=2190
DATA_RETENTION_DAYS_PCI=365
DATA_RETENTION_DAYS_GDPR=1095

# --- Dashboard ---
DASHBOARD_REFRESH_MS=5000
