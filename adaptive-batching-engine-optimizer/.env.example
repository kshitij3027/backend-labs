# Adaptive Batching Engine Optimizer — example environment configuration.
# Copy to `.env` and override as needed. All values shown are the defaults.

# --- Batch size bounds & seed ---
MIN_BATCH_SIZE=50
MAX_BATCH_SIZE=5000
INITIAL_BATCH_SIZE=100

# --- Optimizer dynamics ---
SMOOTHING_ALPHA=0.2
OPTIMIZATION_INTERVAL=5.0
BATCH_INCREASE_FACTOR=1.1
BATCH_DECREASE_FACTOR=0.9

# --- Safety constraint thresholds ---
CPU_CONSTRAINT_THRESHOLD=90.0
MEMORY_CONSTRAINT_THRESHOLD=90.0
LATENCY_CONSTRAINT_THRESHOLD=1000.0

# --- Load simulation defaults ---
DEFAULT_MESSAGES_PER_SECOND=100.0
DEFAULT_BURST_PROBABILITY=0.2

# --- Multi-objective optimization weights ---
WEIGHT_THROUGHPUT=0.7
WEIGHT_LATENCY=0.3

# --- Control-loop internals ---
LEARNING_SAMPLES=5
STABLE_GRADIENT_THRESHOLD=0.01
RECOVERY_CPU_THRESHOLD=70.0
RECOVERY_MEMORY_THRESHOLD=70.0
RECOVERY_LATENCY_THRESHOLD=300.0
RECOVERY_CYCLES=3
METRICS_HISTORY_SIZE=200
DASHBOARD_POINTS=20

# --- API / server ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
