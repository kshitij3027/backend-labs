# JWT settings (REQUIRED — service refuses to start if JWT_SECRET_KEY is missing)
JWT_SECRET_KEY=replace-me-with-a-32-byte-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# CORS (comma-separated allowed origins for the React frontend in dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000
