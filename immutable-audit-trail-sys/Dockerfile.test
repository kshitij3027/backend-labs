# syntax=docker/dockerfile:1.6

# Single-stage tester image. Installs the full runtime deps so the same
# code that ships in the runtime image can be exercised under test.
# ``src/`` and ``tests/`` are bind-mounted at runtime by docker-compose so
# iteration does not require a rebuild.
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        curl \
        jq \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip==24.3.1

WORKDIR /app

COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# src/ and tests/ are bind-mounted by the ``tester`` compose service.
# No USER directive — the tester container is ephemeral.
CMD ["pytest"]
