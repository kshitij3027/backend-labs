# --- Server ---
PORT=8000
LOG_LEVEL=INFO

# --- Persistence ---
DATABASE_URL=sqlite+aiosqlite:////app/data/audit.db

# --- Crypto ---
# 32-byte Ed25519 seed, base64-encoded. Generate with:
#   python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
SIGNING_KEY_B64=CHANGEME_32_BYTES_BASE64_ENCODED_REPLACE_BEFORE_RUNNING==

# --- Chain ---
CHAIN_GENESIS_NOTE=immutable-audit-trail

# --- Reports ---
REPORT_DEFAULT_RANGE_DAYS=30

# --- Dashboard ---
DASHBOARD_REFRESH_MS=10000

# --- Auth headers ---
ANONYMOUS_USER_ID=anonymous
USER_HEADER_NAME=X-User-ID
SESSION_HEADER_NAME=X-Session-ID
