# Predictive Log Analytics Engine — example environment overrides.
#
# Copy to `.env` and adjust. Every variable here overrides the matching default in
# src/config.py (Settings) and config/config.yaml. No real secrets belong in this
# file — it is a committed template.

# --- Server ---
API_PORT=8000
LOG_LEVEL=INFO

# --- Dashboard (React + nginx) host port ---
DASHBOARD_PORT=8080

# --- Persistence / cache (compose service names; override for local/non-Docker runs) ---
DATABASE_URL=postgresql+psycopg2://forecast:forecast@postgres:5432/forecast
REDIS_URL=redis://redis:6379/0

# --- Scheduling cadence ---
PREDICTION_INTERVAL_MIN=5
RETRAIN_INTERVAL_HR=6

# --- Forecast horizon ---
DEFAULT_HORIZON_MIN=60

# --- Confidence / deploy thresholds ---
HIGH_CONFIDENCE_THRESHOLD=0.85
MEDIUM_CONFIDENCE_THRESHOLD=0.65
ACCURACY_DEPLOY_THRESHOLD=0.6
