# NLP Log Processing Engine — example environment overrides.
#
# Copy to `.env` and adjust. Compose reads BACKEND_PORT / FRONTEND_PORT for host port
# mapping; LOG_LEVEL overrides the matching default in src/config.py (Settings — env var
# name = upper-cased field name). No real secrets belong in this file — it is a committed
# template. More vars (NLP tunables: intent-confidence floor, sentiment thresholds, stats
# window, trending top-k, ...) are added here in later commits.

# --- Host ports (docker-compose; override if 8000/3000 are taken) ---
BACKEND_PORT=8000                        # API host port (mapped to uvicorn :8000)
FRONTEND_PORT=3000                       # React dashboard host port (nginx SPA on :80)

# --- Server / logging ---
LOG_LEVEL=INFO                           # root log level (DEBUG | INFO | WARNING | ERROR)
