# NLP Log Processing Engine — example environment overrides.
#
# Copy to `.env` and adjust. Docker Compose reads BACKEND_PORT / FRONTEND_PORT for the host
# port mappings; the backend reads the "Server" and "Stats / dashboard" and "CORS / WebSocket"
# vars via src/config.py (Settings — each env var name is the upper-cased field name). The
# E2E and load gates are read by scripts/verify_e2e.py and scripts/load_test.py respectively
# (via the compose e2e/loadtest services), NOT by the backend. No real secrets belong in this
# file — it is a committed template; the engine has no credentials of any kind.

# --- Host ports (docker-compose; override if 8000/3000 are taken by sibling projects) ---
BACKEND_PORT=8000                        # API host port (mapped to uvicorn :8000)
FRONTEND_PORT=3000                       # React dashboard host port (nginx SPA on :80)

# --- Server / logging ---
LOG_LEVEL=INFO                           # root log level (DEBUG | INFO | WARNING | ERROR)

# --- Stats / dashboard aggregates (src/config.py) ---
STATS_WINDOW=500                         # rolling-window size: bounds the `recent` buffer AND
                                         #   the timestamp window backing throughput_per_sec
TRENDING_TOP_K=10                        # number of trending keywords GET /api/stats returns

# --- CORS / WebSocket live feed (src/config.py) ---
CORS_ORIGINS=*                           # comma-separated allowed origins, or `*` for any.
                                         #   With `*`, credentials are disabled (CORS spec).
                                         #   e.g. CORS_ORIGINS=http://localhost:3000,http://host:3001
WS_ENABLED=true                          # operability switch for the /ws live feed (true|false)

# =======================================================================================
# Verification gates — read by the E2E verifier / load harness, NOT the backend. Defaults
# are calibrated to the measured reality and pass with margin; every gate is host-overridable
# so a deliberately impossible bar proves the gate bites (e.g. MIN_ACCURACY=0.99 make e2e).
# =======================================================================================

# --- E2E verifier gates (make e2e; scripts/verify_e2e.py) ---
MIN_ACCURACY=0.80                        # intent-accuracy floor over ACCURACY_SAMPLES samples
ACCURACY_SAMPLES=40                      # ground-truth samples for accuracy/NER + latency loop
MIN_NER_RECALL=0.80                      # NER recall floor (fraction of GT (text,label) found)
MIN_CRITICAL_RECALL=0.75                 # critical lines must predict critical/negative
MIN_KEYWORDS=1                           # minimum keywords on the crafted analyze line
MAX_P95_MS=500                           # analyze p95 latency ceiling, ms (shared: e2e + load)
E2E_WS_TIMEOUT=10                        # seconds to wait for the WebSocket analysis+stats frames

# --- Load / perf harness gates (make load; scripts/load_test.py) ---
LOAD_MESSAGES=2000                       # total analyze POSTs fired at the backend
LOAD_CONCURRENCY=20                      # max in-flight POSTs (asyncio.Semaphore)
MIN_MSGS_PER_SEC=100                     # throughput floor, successful msgs/second
MAX_BACKEND_MEM_MB=500                   # backend RSS ceiling, MB (shared: e2e + load)
