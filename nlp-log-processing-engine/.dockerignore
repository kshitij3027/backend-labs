# Keep junk and bulky artifacts out of the build context / image. The Dockerfile copies
# only src/ (+ requirements.txt) and Dockerfile.test additionally copies tests/ +
# pytest.ini + scripts/, so most of this is belt-and-braces. tests/ and scripts/ are
# deliberately NOT ignored — the test image needs them in context.

# VCS / planning docs
.git
.gitignore
*.md
README.md
plan.md

# Python caches / build artifacts
__pycache__
*.py[cod]
*.pyc
*$py.class
*.so
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
build
dist
*.egg-info

# Virtual environments
.venv
venv
env
ENV

# Secrets / env
.env

# Frontend (added in a later commit; node_modules must never enter the backend build context)
frontend/node_modules
frontend/dist
node_modules

# OS / logs
.DS_Store
*.log
