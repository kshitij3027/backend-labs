# Log Recommendation Engine — example environment overrides.
#
# Copy to `.env` and adjust. Every variable here overrides the matching default in
# src/config.py (Settings) and config/config.yaml. No real secrets belong in this
# file — it is a committed template.

# --- Server ---
API_PORT=8000
LOG_LEVEL=INFO

# --- Dashboard (React + nginx) host port ---
DASHBOARD_PORT=8080

# --- Persistence / cache (compose service names; override for local/non-Docker runs) ---
DATABASE_URL=postgresql+psycopg2://recommend:recommend@postgres:5432/recommend
REDIS_URL=redis://redis:6379/0

# --- Ranking tunables (examples; the live defaults live in config/config.yaml) ---
# The blended relevance score = WEIGHT_SEMANTIC*semantic + WEIGHT_CONTEXTUAL*contextual,
# with a Laplace-smoothed WEIGHT_FEEDBACK*net_help boost folded in (see README/plan).
# Uncomment any of these to override at runtime.
# WEIGHT_SEMANTIC=0.6
# WEIGHT_CONTEXTUAL=0.4
# WEIGHT_FEEDBACK=0.2
# RECENCY_HALF_LIFE_DAYS=30
# TOP_K=5
# EPSILON_EXPLORE=0.1
