# Keep junk and bulky artifacts out of the build context / image. The Dockerfile and
# Dockerfile.test copy only what they need (src/, config/, tests/, pytest.ini,
# scripts/, data/), so be careful not to exclude scripts/ or data/.gitkeep.

# VCS / planning docs
.git
.gitignore
plan.md
project_requirements.md
README.md

# Python caches / build artifacts
__pycache__
*.py[cod]
*$py.class
*.so
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
build
dist
*.egg-info

# Virtual environments
.venv
venv
env

# Fitted models + generated datasets (the dirs themselves are kept via .gitkeep, but
# their heavyweight contents must never enter the build context).
models/*
!models/.gitkeep
data/*.csv
data/*.jsonl
data/*.pkl
data/*.npz

# Frontend (added in a later commit)
frontend/node_modules
frontend/dist
node_modules

# OS / logs
.DS_Store
*.log
