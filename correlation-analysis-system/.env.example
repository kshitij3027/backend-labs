# Correlation Analysis System — example environment overrides.
#
# Copy to `.env` and adjust. Compose reads the *_PORT variables for host port
# mapping; everything else overrides the matching default in src/config.py
# (Settings — env var name = upper-cased field name). No real secrets belong in
# this file — it is a committed template.

# --- Host ports (docker-compose) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
REDIS_PORT=6379

# --- Infrastructure ---
# Compose overrides this to redis://redis:6379/0 for in-network services; the
# localhost form is for bare-host runs.
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO

# --- Core pipeline tunables ---
WINDOW_SECONDS=30
EVENTS_PER_SECOND=135
DETECTION_INTERVAL_SECONDS=2.0
PIPELINE_ENABLED=true

# --- Remaining tunables (defaults shown; uncomment to override) ---
# GENERATION_INTERVAL_SECONDS=1.0   # pipeline tick: generate/parse/buffer/aggregate every N seconds
# EVENT_BUFFER_SIZE=5000            # max parsed events kept in the in-memory deque
# MIN_SAMPLES=10                    # min paired samples before a metric correlation is attempted
# FDR_Q=0.05                        # Benjamini-Hochberg false-discovery-rate level per detection cycle
# CASCADE_WINDOW_SECONDS=10         # max spacing between ordered errors that still chains a cascade
# DEDUP_TTL_SECONDS=30              # emitted-correlation dedupe cache TTL (seconds)
# ALERT_STRENGTH_THRESHOLD=0.8      # min correlation strength before the alert rule fires
# ALERT_CONFIDENCE_THRESHOLD=0.6    # min correlation confidence before the alert rule fires
# ALERT_COOLDOWN_SECONDS=60         # per-(rule, pair) alert cooldown (seconds)
# SCENARIO_PERIOD_SECONDS=45        # a new injected incident scenario starts every N seconds
# SCENARIO_DURATION_SECONDS=20      # each injected incident scenario lasts N seconds
