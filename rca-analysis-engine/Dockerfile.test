# syntax=docker/dockerfile:1.6
#
# Test-runner image for the RCA Analysis Engine.
#
# Same base, env and dependencies as the production image so tests exercise the real
# code path, but it additionally COPYs the test suite + pytest config + scripts/, and
# runs as root (tests write temp files freely). Built and run via `make test` / the
# `test` compose profile; it never starts on a bare `docker compose up`. The e2e /
# loadtest compose profiles (C10) reuse this same image to run scripts/ against the
# live backend.

FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app

WORKDIR /app

# Parity with production: curl (handy for in-container probes; numpy/scipy come as
# prebuilt manylinux wheels, so no build toolchain).
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Install dependencies first (cached unless requirements.txt changes).
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# App code + the test suite and its config, plus scripts/ (the C10 E2E verifier and
# load-test harness live there; the e2e/loadtest compose profiles run them from this
# same image). scripts/ ships an __init__.py from C1 so this COPY always succeeds.
COPY src/ ./src/
COPY tests/ ./tests/
COPY pytest.ini ./
COPY scripts/ ./scripts/

CMD ["pytest", "-q"]
