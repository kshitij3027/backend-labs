# RCA Analysis Engine — example environment overrides.
#
# Copy to `.env` and adjust. Compose reads BACKEND_PORT for host port mapping;
# everything else overrides the matching default in src/config.py (Settings — env var
# name = upper-cased field name). No real secrets belong in this file — it is a
# committed template.

# --- Host ports (docker-compose) ---
BACKEND_PORT=8000
# FRONTEND_PORT=3000                     # React dashboard host port (added in a later commit)

# --- Server / logging ---
# SERVER_PORT=8000                       # uvicorn bind port inside the container
# CORS_ORIGINS=*                         # comma-separated allowed origins, or * for any
# LOG_LEVEL=INFO

# --- Causal-edge scoring (strength = base + dep_bonus + errorprop_bonus - gap_penalty, clamped) ---
# TEMPORAL_WINDOW=300                    # max seconds between two events for a causal edge
# BASE_CAUSAL_STRENGTH=0.5               # base edge strength before bonuses/penalties
# SERVICE_DEPENDENCY_BONUS=0.3           # + bonus when the map declares the dependency
# ERROR_PROPAGATION_BONUS=0.2            # + bonus for an ERROR -> ERROR edge
# TEMPORAL_GAP_THRESHOLD=60              # seconds beyond which the gap penalty applies
# TEMPORAL_GAP_PENALTY=0.1               # - penalty when the inter-event gap exceeds the threshold
# CAUSAL_STRENGTH_MIN=0.1                # edge-strength clamp floor
# CAUSAL_STRENGTH_MAX=1.0                # edge-strength clamp ceiling

# --- Confidence scoring (severity + temporal position + normalized out-degree centrality) ---
# SCORE_CRITICAL=0.6                     # severity score for a CRITICAL event
# SCORE_ERROR=0.4                        # severity score for an ERROR event
# SCORE_WARNING=0.2                      # severity score for a WARNING event
# TEMPORAL_SCORE_WEIGHT=0.3              # weight on temporal position (earlier => higher)
# CENTRALITY_SCORE_WEIGHT=0.2            # weight on normalized out-degree centrality

# --- Incident history / live stream ---
# MAX_INCIDENT_HISTORY=1000              # max incidents retained in the in-memory history
# LIVE_STREAM_ENABLED=false              # background live-stream loop (added in C8; off by default)

# --- Service dependency map ---
# SERVICE_DEPENDENCY_MAP_PATH=src/config/service_dependency_map.json
