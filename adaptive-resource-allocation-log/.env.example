# Adaptive Resource Allocation System — example environment variables.
#
# Copy to .env and adjust as needed. Every variable here overrides the matching
# field in src/config.py (env wins over the YAML file and dataclass defaults).
# No real secrets belong in this repo.

# --- Server / dashboard ---
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# --- Worker bounds ---
MIN_WORKERS=2
MAX_WORKERS=20

# --- Scaling thresholds (percent) ---
CPU_THRESHOLD_SCALE_UP=75
MEMORY_THRESHOLD_SCALE_UP=80

# --- Cooldowns / loop cadence (seconds) ---
COOLDOWN_PERIOD_SECONDS=60
MONITORING_INTERVAL_SECONDS=5

# --- History retention ---
HISTORY_WINDOW_MINUTES=15
METRICS_RETENTION_HOURS=24

# --- Forecast ---
HORIZON_MINUTES=10
CONFIDENCE_THRESHOLD=0.70

# --- Workload model (msgs/sec) ---
BASE_ARRIVAL_RATE=500
CAPACITY_PER_WORKER=400

# --- Worker backend ---
# Set USE_DOCKER=1 to run real Docker worker containers instead of the simulator.
USE_DOCKER=0
