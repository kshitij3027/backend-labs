# ML Log Classifier — example environment overrides.
#
# Copy to `.env` and tweak. Every key maps to a Settings field in src/config.py by
# its UPPERCASE name and overrides both the dataclass default and config/config.yaml.
# No secrets live here — this project talks to no external services.

# --- Server / dashboard ---
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Path to the YAML config inside the container.
CONFIG_PATH=/app/config/config.yaml

# --- Filesystem locations ---
MODEL_DIR=/app/models
DATA_DIR=/app/data

# --- Sample-data generation / reproducibility ---
SAMPLE_SIZE=1000
RANDOM_SEED=42

# --- TF-IDF feature extraction ---
TFIDF_MAX_FEATURES=5000
TFIDF_NGRAM_MAX=2

# --- Ensemble member hyperparameters ---
RF_N_ESTIMATORS=100
GB_N_ESTIMATORS=100
# Comma-separated soft-voting weights (NaiveBayes,RandomForest,GradientBoosting).
ENSEMBLE_WEIGHTS=1,2,3

# --- Adaptive learning loop ---
ACCURACY_RETRAIN_THRESHOLD=0.90
DRIFT_WINDOW=100

# --- Serving performance ---
TARGET_LATENCY_MS=100
CACHE_SIZE=1024
