# Multi-Tier Caching Layer — example environment configuration.
# Copy to `.env` and override as needed. All values shown are the defaults.

# --- L1 in-process cache ---
L1_MAX_SIZE=1000          # max entries before LRU eviction
L1_MEMORY_MB=100          # soft memory allocation for L1
L1_TTL=300                # default L1 TTL in seconds

# --- L2 distributed cache / Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=                # if empty, derived as redis://REDIS_HOST:REDIS_PORT/0
L2_MAX_MB=2048            # L2 cache size budget
L2_TTL_SECONDS=600        # default L2 TTL in seconds
L2_TIMEOUT=2.0            # per-call Redis timeout in seconds
L2_COMPRESS=true          # compress time-series blobs with zstd

# --- Overall cache budget ---
CACHE_MEM_CAP_MB=200      # total cache memory cap across tiers

# --- L3 / Postgres backend ---
DATABASE_URL=postgresql://cache:cache@postgres:5432/cache
BACKEND_DELAY_MS=150      # artificial slow-backend latency for the demo
TIME_BUCKET_SECONDS=300   # timestamp bucketing for cache keys

# --- Proactive warmer ---
WARMER_INTERVAL_SECONDS=5.0
WARMER_TOP_N=20

# --- Heuristic pattern engine ---
PATTERN_HISTORY_SIZE=5000
PATTERN_FREQ_WEIGHT=1.0
PATTERN_RECENCY_WEIGHT=1.0
PATTERN_COST_WEIGHT=1.0
PATTERN_RECENCY_HALF_LIFE_SECONDS=3600.0

# --- Degradation alerting ---
DEGRADATION_HIT_RATE_THRESHOLD=0.5

# --- Synthetic data seeding ---
SEED_ROWS=200000          # synthetic raw_logs rows
SEED_RANDOM_SEED=1337

# --- Dashboard / WebSocket ---
WS_PUSH_INTERVAL_SECONDS=2.0
DASHBOARD_POINTS=60

# --- API / server ---
API_HOST=0.0.0.0
API_PORT=8000
DASH_PORT=3000
LOG_LEVEL=INFO
