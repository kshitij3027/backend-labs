# --- Server ---
PORT=8000
LOG_LEVEL=INFO

# --- Persistence ---
DATABASE_URL=sqlite+aiosqlite:///data/retention.db

# --- Storage tiers ---
STORAGE_ROOT=/app/data/tiers

# --- Policy config ---
POLICY_CONFIG_PATH=config/retention_config.yaml

# --- Dashboard ---
DASHBOARD_REFRESH_MS=5000

# --- Scheduler intervals (seconds) ---
SCAN_INTERVAL_SEC=60
APPLY_INTERVAL_SEC=60
SWEEP_INTERVAL_SEC=60
DELETE_DELAY_HOURS=24
