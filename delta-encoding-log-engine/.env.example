# Delta Encoding Log Engine — example environment configuration.
# Copy to `.env` and override as needed. All values shown are the defaults.
# Pydantic reads these case-insensitively (UPPER_SNAKE maps to Settings fields).

# --- API / server ---
API_HOST=0.0.0.0   # interface uvicorn binds to (0.0.0.0 so Docker can publish it)
API_PORT=8080      # TCP port of the API + dashboard (also the host port in compose)

# --- delta encoding ---
KEYFRAME_INTERVAL=100       # emit a full keyframe every N entries (storage <-> random-access dial)
DELTA_BASELINE=previous     # diff each entry against `previous` or the segment `keyframe`
GZIP_DELTAS=false           # also gzip the delta stream (delta encoding composes with byte compression)

# --- synthetic log generator ---
GENERATOR_FIELD_CHURN=0.2   # fraction of fields that change between generated entries
GENERATOR_SCHEMA_WIDTH=8    # number of fields per generated entry

# --- pattern analyzer ---
ANALYZER_WINDOW=200         # sliding-window size for the pattern analyzer

# --- reconstruction ---
RECONSTRUCT_CACHE_SIZE=1024 # LRU cache size for reconstructed entries

# --- dashboard ---
DASHBOARD_REFRESH_MS=2000   # dashboard websocket tick cadence (ms)

# --- logging ---
LOG_LEVEL=INFO     # stdlib logging level (DEBUG / INFO / WARNING / ERROR)
