# Identifier for this node in the cluster (REQUIRED, no default).
NODE_ID=node-1

# Set to true on the bootstrap primary; standbys leave this false.
IS_PRIMARY=false

# HTTP port this node binds to (each node gets its own port in compose).
PORT=8001

# Redis coordinates — used for the leader lock, heartbeat, and snapshots.
REDIS_HOST=redis
REDIS_PORT=6379

# Primary writes a heartbeat every HEARTBEAT_INTERVAL seconds.
HEARTBEAT_INTERVAL=2.0

# Standbys treat the primary as failed after HEARTBEAT_TIMEOUT seconds with no heartbeat.
HEARTBEAT_TIMEOUT=6.0

# Maximum total time allowed for an election to complete.
ELECTION_TIMEOUT=10.0

# Primary writes a state snapshot to Redis every STATE_SYNC_INTERVAL seconds.
STATE_SYNC_INTERVAL=5.0

# TTL on the leader:lock key in Redis (seconds). Renewed every HEARTBEAT_INTERVAL.
LOCK_TTL=6

# Comma-separated list of peer host:port addresses for inter-node calls.
PEER_NODES=node-2:8002,node-3:8003
