# ===========================================================================
# Per-node configuration for the active-passive failover log processor.
# Each cluster node loads these from its own environment (the docker-compose
# file passes them in directly per service).
# ===========================================================================

# --- Identity ---------------------------------------------------------------

# Unique identifier for this node in the cluster. REQUIRED — there is no
# default. Used as the value written to the leader:lock key in Redis when
# this node is primary, and as the deterministic seed for election priority
# (priority = md5(NODE_ID)[:4] mod 1000, lowest wins).
NODE_ID=node-1

# Set to true on exactly one bootstrap node so the cluster starts with a
# defined primary. All other nodes must leave this false; on startup they
# enter STANDBY and only promote via election.
IS_PRIMARY=false

# --- Networking -------------------------------------------------------------

# HTTP port this node binds to. In docker-compose each node gets its own
# port (8001/8002/8003) so the host can reach all three for the E2E driver.
PORT=8001

# Redis coordinates — used for the leader lock, primary heartbeat, and
# state snapshots. The hostname matches the redis service in
# docker-compose.yml; use 127.0.0.1 if running outside compose.
REDIS_HOST=redis
REDIS_PORT=6379

# --- Failover timing --------------------------------------------------------

# Primary writes a heartbeat to Redis every HEARTBEAT_INTERVAL seconds and
# also renews the leader lock at this cadence. Default 2s gives 3 chances
# to renew within the lock TTL window.
HEARTBEAT_INTERVAL=2.0

# Standbys treat the primary as failed after HEARTBEAT_TIMEOUT seconds with
# no heartbeat. Default 6s = 3 missed heartbeats at the 2s interval. This
# is the canonical "3 strikes" rule; lowering it speeds detection but
# raises false-positive risk on transient network blips.
HEARTBEAT_TIMEOUT=6.0

# Maximum total time allowed for an election to complete (priority jitter
# + Redis SET NX EX + result broadcast). 10s is the requirement-level
# upper bound for total failover time; the election itself is typically
# under 1s.
ELECTION_TIMEOUT=10.0

# Primary writes a state snapshot (counters, not log payloads) to Redis
# every STATE_SYNC_INTERVAL seconds. The new primary loads the most
# recent snapshot on promotion. This is the upper bound on un-snapshotted
# progress lost on an uncoordinated primary kill.
STATE_SYNC_INTERVAL=5.0

# TTL on the leader:lock key in Redis (seconds). Renewed every
# HEARTBEAT_INTERVAL by the primary. We deliberately set this *shorter*
# than HEARTBEAT_TIMEOUT so the lock has expired by the time standbys
# finish their failure-detection countdown — the winning standby's first
# SET NX EX succeeds rather than contending with a stale lease.
LOCK_TTL=3

# --- Inter-node addressing --------------------------------------------------

# Comma-separated list of peer host:port pairs for inter-node election
# RPCs. The local node is NOT included. In docker-compose this is wired
# pairwise; outside compose, set explicit hostnames or IPs.
PEER_NODES=node-2:8002,node-3:8003

# ===========================================================================
# Dashboard-only configuration (consumed by the dashboard service).
# ===========================================================================

# How often the dashboard server polls every node's /role and /metrics.
# Lower values make the UI feel snappier but generate more cross-network
# chatter; 1.0s is a comfortable default for a 3-node cluster.
DASHBOARD_POLL_INTERVAL=1.0
