# Copy to .env to override defaults. The compose file already supplies sensible defaults.
LOG_LEVEL=INFO
CHAOS_API_HOST=0.0.0.0
CHAOS_API_PORT=8000
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Optional override for the YAML config file (defaults to ./config/safety_config.yaml)
CHAOS_CONFIG_PATH=
# Override individual safety values (each maps to a Settings field with CHAOS_ prefix)
# CHAOS_MAX_CONCURRENT_SCENARIOS=3
# CHAOS_CPU_EMERGENCY_THRESHOLD_PCT=90
# CHAOS_MEM_EMERGENCY_THRESHOLD_PCT=90

# --- Target stack tuning (passed through compose to producer/consumer) ---
# PRODUCE_HZ=10
# REDIS_HOST=redis
# REDIS_PORT=6379
# LOGS_KEY=logs
