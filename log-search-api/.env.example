# --------------------------------------------------------------------------
# Log Search API — example environment file.
#
# Copy this to `.env` (`cp .env.example .env`) and tweak the values for your
# deployment. Every setting is read by `src/config.py` (pydantic-settings).
#
# IMPORTANT: docker compose interpolates `$VAR` and `${VAR}` in env files.
# When a literal `$` must appear (notably in the bcrypt hash), escape it
# as `$$`. Example: a hash `$2b$12$...` is written here as `$$2b$$12$$...`.
# --------------------------------------------------------------------------

# HTTP server
API_HOST=0.0.0.0
API_PORT=8000
PROJECT_NAME=Log Search API
API_V1_PREFIX=/api/v1

# Auth (HS256 JWT). SECRET_KEY MUST be at least 8 chars in dev; 32+ in prod.
SECRET_KEY=change-me-32-bytes-of-random-hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15

# Rate limit (per-user when authenticated, per-IP otherwise).
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Redis: cache and rate-limit storage live on separate logical DBs.
REDIS_URL=redis://redis:6379
CACHE_REDIS_DB=0
RATE_LIMIT_REDIS_DB=1

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=logs

# Search behaviour
SEARCH_CACHE_TTL_SECONDS=300
DEFAULT_SEARCH_LIMIT=100
MAX_SEARCH_LIMIT=1000
DEFAULT_SEARCH_OFFSET=0
DEFAULT_SORT_BY=relevance
DEFAULT_SORT_ORDER=desc
DEFAULT_INCLUDE_CONTENT=true

# CORS — comma-separated origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Seeded user. SEED_PASSWORD_HASH must be a real bcrypt hash. The
# placeholder below is NOT a valid hash and authentication will fail until
# you replace it. Generate one with:
#   docker compose run --rm api python scripts/seed_password.py demo
# Each literal `$` in the hash must be escaped as `$$` in this file so docker
# compose does not try to interpolate it (e.g. `$$2b$$12$$...`).
SEED_USERNAME=demo
SEED_PASSWORD_HASH=$$2b$$12$$KIXqg4fO0e5nQa7xA8X0IO0.U0E1rN8p9F9Q4D1CmS3z1lH8wZpOu

# Logging + diagnostics
LOG_LEVEL=INFO
DEBUG_ENDPOINTS_ENABLED=false

# Set to a non-empty value (e.g. `1`) to enable the load-test smoke
# (tests/integration/test_load.py). Off by default so unit + integration
# runs stay snappy.
LOAD_TEST_ENABLED=
