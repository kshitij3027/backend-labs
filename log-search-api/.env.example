API_HOST=0.0.0.0
API_PORT=8000
PROJECT_NAME=Log Search API
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-32-bytes-of-random-hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
REDIS_URL=redis://redis:6379
CACHE_REDIS_DB=0
RATE_LIMIT_REDIS_DB=1
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=logs
SEARCH_CACHE_TTL_SECONDS=300
DEFAULT_SEARCH_LIMIT=100
MAX_SEARCH_LIMIT=1000
DEFAULT_SEARCH_OFFSET=0
DEFAULT_SORT_BY=relevance
DEFAULT_SORT_ORDER=desc
DEFAULT_INCLUDE_CONTENT=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
SEED_USERNAME=demo
# SEED_PASSWORD_HASH must be a real bcrypt hash. The placeholder below is NOT a
# valid hash and authentication will fail until you replace it.
# Generate a real hash with:
#   docker compose run --rm api python scripts/seed_password.py demo
# Each literal `$` in the hash must be escaped as `$$` so docker compose does
# not try to interpolate it (e.g. `$$2b$$12$$...`).
SEED_PASSWORD_HASH=$$2b$$12$$KIXqg4fO0e5nQa7xA8X0IO0.U0E1rN8p9F9Q4D1CmS3z1lH8wZpOu
LOG_LEVEL=INFO
DEBUG_ENDPOINTS_ENABLED=false
