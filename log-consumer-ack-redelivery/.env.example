# RabbitMQ connection
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Queue / exchange names
MAIN_QUEUE=logs.incoming
MAIN_EXCHANGE=logs.main

# Retry configuration
RETRY_EXCHANGE=logs.retry
RETRY_DELAYS=[1000, 2000, 4000, 8000]

# Dead-letter queue
DLQ_QUEUE=logs.dead_letter
DLQ_EXCHANGE=logs.dlx

# Processing behaviour
MAX_RETRIES=5
ACK_TIMEOUT_SEC=30
PREFETCH_COUNT=10

# Dashboard / testing
DASHBOARD_PORT=8000
FAILURE_RATE=0.2
TIMEOUT_RATE=0.1
