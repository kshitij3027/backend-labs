# Multi-Region Log Replication Engine — environment variables.
#
# Copy to `.env` and tweak as needed. Defaults below match the values in
# `src/config.py` and `project_requirements.md` §7.

# Network bind. Use 0.0.0.0 inside Docker so the port mapping works; switch
# to 127.0.0.1 for host-side runs if you ever bypass Docker.
HOST=0.0.0.0
PORT=8000

# Comma-separated region IDs and the order primary election should prefer.
REGIONS=us-east,europe,asia
PRIMARY_PREFERENCE=us-east,europe,asia

# Replication SLO target (ms). Used for dashboard colouring + assertions in
# the verifier scripts.
REPLICATION_LAG_TARGET_MS=100

# How often the WS broadcaster pushes a fresh snapshot to live clients (s).
WEBSOCKET_PUSH_INTERVAL_SEC=5

# How often the health monitor polls per-region status (s).
HEALTH_CHECK_INTERVAL_SEC=1

# How long the system has to elect a new primary after primary failure (s).
FAILOVER_TIMEOUT_SEC=5

# Default page size for GET /api/logs.
MAX_LOGS_RETURNED=25

# Logging level (DEBUG / INFO / WARNING / ERROR).
LOG_LEVEL=INFO

# Enables POST /api/regions/{id}/kill + /heal — used by E2E tests and the
# Chrome MCP UI flow. Set to false for prod-like deployments.
ALLOW_KILL_ENDPOINT=true
