FROM python:3.11-slim

WORKDIR /app

# gcc + libc-dev cover any wheels we might need to compile from source.
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        libc-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ ./src/
COPY tests/ ./tests/
# ``web/`` ships in here so test_get_index_returns_html can read the
# dashboard HTML — without it the GET / route would 500 inside the
# test container even though the file exists at the repo root.
COPY web/ ./web/
COPY pytest.ini ./pytest.ini

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

CMD ["pytest", "-v", "--tb=short"]
