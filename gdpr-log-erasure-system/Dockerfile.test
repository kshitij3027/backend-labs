# syntax=docker/dockerfile:1.6
#
# Single-stage tester image. Installs the full requirements (including
# test deps) and bakes the project in. docker-compose bind-mounts the
# project over /app at run time so edits to src/ or tests/ are picked
# up without rebuilding.
#
# curl + jq are present so shell-driven E2E probes (scripts/e2e.sh in a
# later commit) can hit the live app and parse JSON responses.
# libpq5 is the runtime lib asyncpg loads when the test suite hits
# PostgreSQL via the integration tester.

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl jq libpq5 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

COPY . /app/

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

CMD ["pytest", "-v"]
