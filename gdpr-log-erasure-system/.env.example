# --- Persistence ---
DATABASE_URL=postgresql+asyncpg://erasure_user:changeme@postgres:5432/gdpr_erasure
REDIS_URL=redis://redis:6379/0

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Anonymization policy ---
ANONYMIZABLE_DATA_TYPES=analytics_events,performance_metrics,system_logs,aggregated_data
ANONYMIZATION_HASH_SALT=change-me-in-production

# --- Erasure execution ---
MAX_PARALLEL_LOCATION_ERASURES=10
ERASURE_RETRY_COUNT=3
ERASURE_RETRY_BACKOFF_SECONDS=2

# --- HTTP ---
CORS_ALLOWED_ORIGINS=*

# --- Observability ---
LOG_LEVEL=INFO

# --- Compliance ---
VERIFICATION_ENABLED=true

# --- Dashboard ---
DASHBOARD_REFRESH_MS=5000
